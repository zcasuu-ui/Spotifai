<?xml version='1.0' encoding='utf-8'?>
<widget id="com.miokaraoke.app" version="1.0.0"
    xmlns="http://www.w3.org/ns/widgets"
    xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <name>Mio Karaoke</name>
    <description>Karaoke personale con Spotify</description>
    <author email="tu@email.com" href="https://extraordinary-syrniki-c25a7e.netlify.app">Tu</author>

    <content src="index.html" />

    <preference name="DisallowOverscroll" value="true" />
    <preference name="android-minSdkVersion" value="22" />
    <preference name="android-targetSdkVersion" value="33" />
    <preference name="Fullscreen" value="false" />
    <preference name="BackgroundColor" value="0xff0a0a0f" />
    <preference name="LoadUrlTimeoutValue" value="700000" />
    <preference name="AndroidPersistentFileLocation" value="Compatibility" />

    <!-- Permette al WebView di caricare URL esterni (Spotify, lrclib) -->
    <allow-navigation href="*" />
    <allow-intent href="*" />

    <platform name="android">
        <allow-intent href="market:*" />
        <!-- Icona di default -->
        <icon src="www/icon.png" />
    </platform>

    <!-- Plugin WebView aggiornato — fondamentale per Android 5.1 -->
    <plugin name="cordova-plugin-ionic-webview" spec="^5.0.0" />
    <plugin name="cordova-plugin-whitelist" spec="^1.3.4" />

</widget>
